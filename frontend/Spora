                    onChange={e => setStatusFilter(e.target.value)}>
                    <option value="">Все статусы</option>
                    {STATUSES.map(s => <option key={s} value={s}>{s}</option>)}
                </select>
                <input className="border p-2 rounded" placeholder="Пользователь"
                    value={usernameFilter} onChange={e => setUsernameFilter(e.target.value)} />
                <input className="border p-2 rounded w-32" type="number" placeholder="Сумма от"
                    value={minAmount} onChange={e => setMinAmount(e.target.value)} />
                <input className="border p-2 rounded w-32" type="number" placeholder="до"
                    value={maxAmount} onChange={e => setMaxAmount(e.target.value)} />
                <button type="submit" className="bg-blue-500 text-white px-4 py-2 rounded">Найти</button>
            </form>

            {/* Список заказов */}
            {orders.map(o => (
                <div key={o.id} className="bg-white p-4 rounded shadow mb-2">
                    <div className="flex flex-col sm:flex-row justify-between gap-2">
                        <div>
                            <span className="font-bold">Заказ #{o.id}</span>
                            <span className="text-sm text-gray-500 ml-2">Пользователь: {o.username}</span>
                        </div>
                        <select value={o.status}
