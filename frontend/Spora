import { useState, useEffect, useCallback } from 'react';
import { getProducts, getReviews, createReview, deleteReview } from '../api';

export default function ProductDetailPage({ productId, onBack }) {
    const [product, setProduct] = useState(null);
    const [reviews, setReviews] = useState([]);
    const [loading, setLoading] = useState(true);
    const [rating, setRating] = useState(5);
    const [comment, setComment] = useState('');
    const [message, setMessage] = useState('');

    const loadProduct = useCallback(async () => {
        const data = await getProducts({});
        const found = data.find(p => p.id === productId);
        setProduct(found);
    }, [productId]);

    const loadReviews = useCallback(async () => {
        try {
            const data = await getReviews(productId);
            setReviews(data);
        } catch {
            setReviews([]);
        }
    }, [productId]);

    const loadAll = useCallback(async () => {
        setLoading(true);
        await Promise.all([loadProduct(), loadReviews()]);
        setLoading(false);
    }, [loadProduct, loadReviews]);

    useEffect(() => { loadAll(); }, [loadAll]);

    const handleSubmitReview = async (e) => {
        e.preventDefault();
        setMessage('');
        try {
            await createReview(productId, { rating, comment });
            setComment('');
            setRating(5);
            setMessage('Отзыв добавлен!');
            loadReviews();
        } catch (err) {
            setMessage(err.message);
        }
    };

    const handleDeleteReview = async (reviewId) => {
        try {
            await deleteReview(reviewId);
            loadReviews();
        } catch (err) {
            alert(err.message);
        }
    };

    if (loading) return <p className="text-gray-500 text-center py-8">Загрузка...</p>;
    if (!product) return <p className="text-red-500 text-center py-8">Товар не найден</p>;

    const avgRating = reviews.length > 0
        ? (reviews.reduce((sum, r) => sum + r.rating, 0) / reviews.length).toFixed(1)
        : null;

    return (
        <div>
            <button onClick={onBack} className="mb-4 text-blue-500 hover:underline">← Назад в каталог</button>

            {/* Карточка товара */}
            <div className="bg-white rounded-lg shadow p-6 mb-6">
                <h2 className="text-2xl font-bold">{product.name}</h2>
                <p className="text-gray-500 mt-2">{product.description}</p>
                <div className="flex items-center gap-4 mt-4">
                    <span className="text-3xl font-bold text-green-600">{product.price} ₽</span>
                    {avgRating && (
                        <span className="text-yellow-500 text-xl">
                            {'★'.repeat(Math.round(avgRating))} {avgRating}
                        </span>
                    )}
                    <span className="text-gray-400">({reviews.length} отзывов)</span>
                </div>
            </div>

            {/* Форма отзыва */}
            <div className="bg-white rounded-lg shadow p-6 mb-6">
                <h3 className="font-bold text-lg mb-3">Оставить отзыв</h3>
                {message && (
                    <p className={`mb-3 text-sm ${message.includes('добавлен') ? 'text-green-600' : 'text-red-500'}`}>
                        {message}
                    </p>
                )}
                <form onSubmit={handleSubmitReview} className="flex flex-col gap-3">
                    <div className="flex items-center gap-2">
                        <span className="text-sm text-gray-600">Оценка:</span>
                        {[1, 2, 3, 4, 5].map(star => (
                            <button
                                key={star}
                                type="button"
                                onClick={() => setRating(star)}
                                className={`text-2xl ${star <= rating ? 'text-yellow-500' : 'text-gray-300'}`}
                            >
                                ★
                            </button>
                        ))}
                    </div>
                    <textarea
                        className="border p-2 rounded w-full"
                        rows="3"
                        placeholder="Ваш отзыв (необязательно)"
                        value={comment}
                        onChange={e => setComment(e.target.value)}
                    />
                    <button type="submit" className="bg-blue-500 text-white px-4 py-2 rounded self-start">
                        Отправить
                    </button>
                </form>
            </div>

            {/* Список отзывов */}
            <div className="bg-white rounded-lg shadow p-6">
                <h3 className="font-bold text-lg mb-3">Отзывы ({reviews.length})</h3>
                {reviews.length === 0 && <p className="text-gray-400">Пока нет отзывов</p>}
                {reviews.map(review => (
                    <div key={review.id} className="border-b last:border-0 py-3">
                        <div className="flex justify-between items-start">
                            <div>
                                <span className="font-medium">{review.username}</span>
                                <span className="text-yellow-500 ml-2">{'★'.repeat(review.rating)}</span>
                            </div>
                            <div className="flex items-center gap-2">
                                <span className="text-sm text-gray-400">
                                    {new Date(review.createdAt).toLocaleString('ru-RU')}
