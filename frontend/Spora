Шаг 1. Создаём сущность Category
В пакете model создаём новый файл:

java
package com.example.demo.model;

import com.fasterxml.jackson.annotation.JsonIgnore;
import jakarta.persistence.*;
import lombok.*;

import java.util.HashSet;
import java.util.Set;

@Entity
@Table(name = "categories")
@Getter
@Setter
@NoArgsConstructor
@AllArgsConstructor
@Builder
public class Category {

    @Id
    @GeneratedValue(strategy = GenerationType.IDENTITY)
    private Long id;

    @Column(nullable = false, unique = true)
    private String name;

    // Связь многие ко многим с Product
    // mappedBy указывает, что эта сторона НЕ владелец связи
    // владелец — поле categories в классе Product
    @ManyToMany(mappedBy = "categories")
    @JsonIgnore      // чтобы не зациклить JSON
    @ToString.Exclude // чтобы Lombok не упал в рекурсию
    @Builder.Default
    private Set<Product> products = new HashSet<>();
}
Что здесь происходит
@ManyToMany(mappedBy = "categories") — говорит JPA: "Я не владелец связи. Владелец — поле categories в классе Product. Всё управление связью делай через него."

mappedBy — это имя поля в классе Product, которое ссылается на Category

Set<Product> — коллекция товаров. Используем Set, а не List, потому что JPA для ManyToMany рекомендует Set (производительнее и не бывает дубликатов)

@Builder.Default — чтобы билдер не перезаписал пустой HashSet на null

