private OrderDto toDto(Order order) {
    List<OrderItemDto> items = order.getOrderItems().stream()
            .map(item -> {
                // Рассчитываем скидку
                Double discountPercent = null;
                Double discountAmount = null;

                if (item.getProduct().getDiscount() != null) {
                    var discount = item.getProduct().getDiscount();
                    if (discount.getType() == DiscountType.PERCENT) {
                        discountPercent = discount.getValue();
                        discountAmount = item.getPriceAtOrder() * discount.getValue() / 100;
                    } else {
                        discountAmount = discount.getValue();
                    }
                }

                return OrderItemDto.builder()
                        .id(item.getId())
                        .productName(item.getProduct().getName())
                        .quantity(item.getQuantity())
                        .priceAtOrder(item.getPriceAtOrder())
                        .discountPercent(discountPercent)
                        .discountAmount(discountAmount)
                        .finalPrice(item.getFinalPrice())
                        .build();
            })
            .toList();

    return OrderDto.builder()
            .id(order.getId())
            .orderDate(order.getOrderDate())
            .status(order.getStatus())
            .username(order.getUser().getUsername())
            .totalAmount(order.getTotalAmount())
            .items(items)
            .build();
}
