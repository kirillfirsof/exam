private ProductDto toDto(Product product) {
    // Скидка
    DiscountDto discountDto = null;
    if (product.getDiscount() != null) {
        Discount d = product.getDiscount();
        discountDto = DiscountDto.builder()
                .id(d.getId())
                .type(d.getType())
                .value(d.getValue())
                .build();
    }

    // Категории — преобразуем каждую Category в CategoryDto
    List<CategoryDto> categoryDtos = product.getCategories().stream()
            .map(cat -> CategoryDto.builder()
                    .id(cat.getId())
                    .name(cat.getName())
                    .build())
            .toList();

    return ProductDto.builder()
            .id(product.getId())
            .name(product.getName())
            .description(product.getDescription())
            .price(product.getPrice())
            .stock(product.getStock())
            .discount(discountDto)
            .categories(categoryDtos)   // ← добавляем категории
            .build();
}
