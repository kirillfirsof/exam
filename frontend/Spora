package com.example.demo.service;

import com.example.demo.controller.ReviewDto;
import com.example.demo.exception.BadRequestException;
import com.example.demo.exception.ResourceNotFoundException;
import com.example.demo.model.Product;
import com.example.demo.model.Review;
import com.example.demo.model.UserEntity;
import com.example.demo.repository.ProductRepository;
import com.example.demo.repository.ReviewRepository;
import com.example.demo.repository.UserRepository;
import com.example.demo.security.SecurityUtils;
import lombok.RequiredArgsConstructor;
import org.springframework.stereotype.Service;
import org.springframework.transaction.annotation.Transactional;

import java.util.List;

@Service
@RequiredArgsConstructor
@Transactional
public class ReviewService {

    private final ReviewRepository reviewRepository;
    private final ProductRepository productRepository;
    private final UserRepository userRepository;
    private final SecurityUtils securityUtils;

    // Создать отзыв
    public ReviewDto create(Long productId, ReviewDto dto) {
        String username = securityUtils.getCurrentUsername();
        UserEntity user = userRepository.findByUsername(username)
                .orElseThrow(() -> new ResourceNotFoundException("Пользователь не найден"));

        // Проверяем, не оставлял ли уже отзыв на этот товар
        if (reviewRepository.existsByUserIdAndProductId(user.getId(), productId)) {
            throw new BadRequestException("Вы уже оставили отзыв на этот товар");
        }

        // Проверяем рейтинг
        if (dto.getRating() < 1 || dto.getRating() > 5) {
            throw new BadRequestException("Рейтинг должен быть от 1 до 5");
        }

        Product product = productRepository.findById(productId)
                .orElseThrow(() -> new ResourceNotFoundException("Товар не найден"));

        Review review = Review.builder()
                .rating(dto.getRating())
                .comment(dto.getComment())
                .user(user)
                .product(product)
                .build();

        Review saved = reviewRepository.save(review);
        return toDto(saved);
    }

    // Все отзывы на товар
    @Transactional(readOnly = true)
    public List<ReviewDto> getByProduct(Long productId) {
        return reviewRepository.findByProductId(productId)
                .stream()
                .map(this::toDto)
                .toList();
    }

    // Мои отзывы
    @Transactional(readOnly = true)
    public List<ReviewDto> getMyReviews() {
        String username = securityUtils.getCurrentUsername();
        UserEntity user = userRepository.findByUsername(username)
                .orElseThrow(() -> new ResourceNotFoundException("Пользователь не найден"));
        return reviewRepository.findByUserId(user.getId())
                .stream()
                .map(this::toDto)
                .toList();
    }

    // Удалить отзыв (свой)
    public void delete(Long id) {
        String username = securityUtils.getCurrentUsername();
        Review review = reviewRepository.findById(id)
                .orElseThrow(() -> new ResourceNotFoundException("Отзыв не найден"));

        if (!review.getUser().getUsername().equals(username)) {
            throw new BadRequestException("Вы можете удалить только свой отзыв");
        }

        reviewRepository.delete(review);
    }

    // Средний рейтинг товара
    @Transactional(readOnly = true)
    public Double getAverageRating(Long productId) {
        List<Review> reviews = reviewRepository.findByProductId(productId);
        if (reviews.isEmpty()) return null;
        return reviews.stream()
                .mapToInt(Review::getRating)
                .average()
                .orElse(0.0);
    }

    // ===== Преобразование =====

    private ReviewDto toDto(Review review) {
        return ReviewDto.builder()
                .id(review.getId())
                .rating(review.getRating())
                .comment(review.getComment())
                .username(review.getUser().getUsername())
                .productId(review.getProduct().getId())
                .productName(review.getProduct().getName())
                .createdAt(review.getCreatedAt())
                .build();
    }
}
